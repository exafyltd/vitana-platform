    { "name": "get_vitana_index",                 "implementations": ["vertex"], "safety_critical": false, "owner_vtid": "VTID-01983" },
    { "name": "get_index_improvement_suggestions","implementations": ["vertex"], "safety_critical": false, "owner_vtid": "VTID-01983" },
