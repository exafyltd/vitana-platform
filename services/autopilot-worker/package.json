{
  "name": "autopilot-worker",
  "version": "0.1.0",
  "private": true,
  "description": "Dev Autopilot worker — polls Supabase queue + runs LLM tasks via `claude -p` against the Claude subscription. Move the LLM billing off the gateway's pay-per-token API key onto a Claude Pro/Max subscription.",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "test:watch": "jest --watch"
  },
  "dependencies": {
    "dotenv": "^16.3.1"
  },
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "@types/node": "^20.10.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.3.0"
  },
  "engines": {
    "node": ">=20"
  }
}
