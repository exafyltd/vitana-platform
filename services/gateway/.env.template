PORT=8080
NODE_ENV=production
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE=your-service-role-key-here
DATABASE_URL=postgresql://postgres:password@host:5432/postgres

# VTID-01228: Daily.co Video Integration for LIVE Rooms
DAILY_API_KEY=your-daily-api-key-here

# VTID-01153: Memory Indexer (Mem0 OSS) - REQUIRED for persistent memory
# Without this, memory will silently fail and users will experience "memory loss"
MEMORY_INDEXER_URL=http://memory-indexer:8080
GCP_PROJECT_ID=lovable-vitana-vers1

# VTID-01200: Visual Verification with Playwright MCP
MCP_GATEWAY_URL=http://localhost:3001
FRONTEND_URL=https://temp-vitana-v1.lovable.app
VISUAL_TEST_SCREENSHOTS_DIR=/tmp/visual-tests

# VTID-01225: Cognee Entity Extraction Service
# Required for automatic entity extraction from conversations and diary entries
COGNEE_EXTRACTOR_URL=http://cognee-extractor:8080

# VTID-01023: Google Gemini API (for LLM routing)
# Either GOOGLE_GEMINI_API_KEY or Vertex AI (GCP_PROJECT_ID) must be configured
GOOGLE_GEMINI_API_KEY=your-gemini-api-key-here

# VTID-01184: OpenAI API (primary embedding provider for semantic memory)
# Falls back to Gemini text-embedding-004 if unavailable
OPENAI_API_KEY=your-openai-api-key-here

# VTID-01216: Perplexity Web Search API
# Required for web search functionality in retrieval router
PERPLEXITY_API_KEY=your-perplexity-api-key-here

# VTID-01216: GitHub API (for CI/CD operations)
GITHUB_TOKEN=your-github-token-here

# BOOTSTRAP-INTENT-COVER-GEN: Find-a-Match cover-photo generator
# Runs through Vertex AI Imagen on the same GCP project the gateway
# already authenticates against (no extra vendor key). The Cloud Run
# service account needs the `roles/aiplatform.user` role.
#
#   VERTEX_IMAGES_MODEL              imagen-3.0-fast-generate-001 (default)
#                                    | imagen-3.0-generate-002 (higher quality, slower)
#   INTENT_COVERS_BUCKET             intent-covers (default; must exist in Supabase Storage)
#   INTENT_COVER_RATE_LIMIT_PER_DAY  10 (per requester user_id, 0 disables)
#   INTENT_COVER_DRY_RUN             true skips Imagen and uses the curated
#                                    fallback library (set in CI / dev).
#
# Re-uses GOOGLE_CLOUD_PROJECT / GCP_PROJECT and VERTEX_LOCATION from the
# Vertex (Gemini) plumbing already wired up.
VERTEX_IMAGES_MODEL=imagen-3.0-fast-generate-001
INTENT_COVERS_BUCKET=intent-covers
INTENT_COVER_RATE_LIMIT_PER_DAY=10
INTENT_COVER_DRY_RUN=false
