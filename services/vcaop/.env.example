# VCAOP dev/staging environment — PLACEHOLDERS ONLY (runbook Sec. 1.3).
# Never put real secret material here. Secrets live in Cloud Secret Manager by reference.

# Environment classification consumed by guardrails/env-boundary.ts.
# Allowed: dev | development | staging | test. Anything else (incl. unset) is treated as prod => refused.
VCAOP_ENV=dev

# Dev Supabase (references/placeholders only — real values are a runtime human task / BLOCKERS.md BLK-001)
SUPABASE_URL=https://YOUR-DEV-PROJECT.supabase.co
SUPABASE_SERVICE_ROLE=__SET_VIA_SECRET_MANAGER__

# GCP (dev). Deploys go to *-dev services or tagged no-traffic Gateway revisions only.
GOOGLE_CLOUD_PROJECT=lovable-vitana-vers1
VERTEX_LOCATION=us-central1

# Cost guard — per-provider daily external call cap (runbook Sec. 0.5; default 100)
VCAOP_PROVIDER_DAILY_CALL_CAP=100
