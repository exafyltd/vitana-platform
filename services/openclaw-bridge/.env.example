# =============================================================================
# Vitana Autopilot (OpenClaw Bridge) - Environment Variables
# =============================================================================
# Copy to .env and fill in your values.

# --- Required ---
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE=your-service-role-key
GATEWAY_URL=http://localhost:8080

# --- OpenClaw ---
OPENCLAW_HOME=/opt/vitana-autopilot
OPENCLAW_LLM_PROVIDER=anthropic
OPENCLAW_LLM_MODEL=claude-sonnet-4-6
OPENCLAW_HEALTH_MODEL=llama3.1:8b
OPENCLAW_WORKSPACE_ISOLATION=tenant_namespaces
OPENCLAW_DISABLED_SKILLS=shell,browser,file

# --- HTTP Channel ---
OPENCLAW_CHANNEL_ENABLED=true
OPENCLAW_CHANNEL_PORT=8080
OPENCLAW_CHANNEL_PATH=/vitana-webhook

# --- Heartbeat ---
OPENCLAW_HEARTBEAT_ENABLED=true
OPENCLAW_HEARTBEAT_INTERVAL_MS=900000

# --- Governance ---
OPENCLAW_ENFORCE_GOVERNANCE=true

# --- Ollama (local LLM for PHI) ---
OLLAMA_URL=http://localhost:11434
